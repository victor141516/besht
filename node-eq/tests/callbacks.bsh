let names = ["alice", "bob", "anna"]
let upper = names.map(name => name.toUpperCase())
console.log(upper.join(","))

let aNames = upper.filter(name => name.startsWith("A"))
console.log(aNames.join(","))

let marked = names.map((name: string) => name + "!")
console.log(marked.join("|"))

let withB = marked.filter(name => name.includes("b"))
console.log(withB.join(","))
