let truncPos = Math.trunc(3.9)
let truncNeg = Math.trunc(-3.9)
console.log(`Math.trunc(3.9): ${truncPos}`)
console.log(`Math.trunc(-3.9): ${truncNeg}`)

let signNeg = Math.sign(-7)
let signZero = Math.sign(0)
let signPos = Math.sign(8)
console.log(`Math.sign(-7): ${signNeg}`)
console.log(`Math.sign(0): ${signZero}`)
console.log(`Math.sign(8): ${signPos}`)

let sample = "besht"
console.log(`charAt(1): ${sample.charAt(1)}`)
console.log(`charAt(1.9): ${sample.charAt(1.9)}`)
console.log(`charAt(-1.9): ${sample.charAt(-1.9)}`)
console.log(`charAt(99): ${sample.charAt(99)}`)

console.log(`substring(4,1): ${sample.substring(4, 1)}`)
console.log(`substring(-2,3): ${sample.substring(-2, 3)}`)
console.log(`substring(2): ${sample.substring(2)}`)
console.log(`string lastIndexOf s: ${sample.lastIndexOf("s")}`)
console.log(`string lastIndexOf z: ${sample.lastIndexOf("z")}`)
console.log(`string lastIndexOf sh: ${"besht shell besht".lastIndexOf("sh")}`)
console.log(`string lastIndexOf missing: ${sample.lastIndexOf("z")}`)
console.log(`string lastIndexOf repeated: ${"bananana".lastIndexOf("na")}`)
console.log(`indexOf s from 3.9: ${sample.indexOf("s", 3.9)}`)
console.log(`indexOf empty default: ${sample.indexOf("")}`)
console.log(`indexOf empty past end: ${sample.indexOf("", 99)}`)
console.log(`lastIndexOf s from 2.9: ${sample.lastIndexOf("s", 2.9)}`)
console.log(`lastIndexOf empty from 2.9: ${sample.lastIndexOf("", 2.9)}`)
console.log(`includes s from 3.9: ${sample.includes("s", 3.9)}`)
console.log(`startsWith sh from 2: ${sample.startsWith("sh", 2)}`)
console.log(`startsWith b from negative: ${sample.startsWith("b", -2.8)}`)
console.log(`endsWith bes length 3.9: ${sample.endsWith("bes", 3.9)}`)
console.log(`endsWith empty negative: ${sample.endsWith("", -2.8)}`)

let letters = ["a", "b", "c", "b"]
console.log(`lastIndexOf b: ${letters.lastIndexOf("b")}`)
console.log(`lastIndexOf z: ${letters.lastIndexOf("z")}`)
console.log(`list toString: ${letters.toString()}`)
console.log(`list toString spaces: ${["a b", "c d"].toString()}`)
letters.unshift("zero")
console.log(`unshift order: ${letters.join(",")}`)
let inertPayload = "$(printf should-not-run)"
console.log(`string hostile indexOf: ${sample.indexOf(inertPayload)}`)
console.log(`string hostile includes: ${sample.includes(inertPayload)}`)
console.log(`list hostile lastIndexOf: ${["a", inertPayload, "b", inertPayload].lastIndexOf(inertPayload)}`)

let ordered = Array.of("x", "y", "z")
console.log(`Array.of order: ${ordered.join(",")}`)
let inertOrdered = Array.of("x", inertPayload, "z")
console.log(`Array.of hostile lastIndexOf: ${inertOrdered.lastIndexOf(inertPayload)}`)
let empty = Array.of()
console.log(`Array.of empty length: ${empty.length}`)
console.log(`Array.of empty join: ${empty.join(",")}`)
console.log(`Array.of empty toString: ${empty.toString()}`)
console.log(`Array.isArray literal: ${Array.isArray(["a", "b"])}`)
console.log(`Array.isArray Array.of: ${Array.isArray(ordered)}`)
console.log(`Array.isArray Array.from: ${Array.isArray(Array.from({ length: 2 }))}`)
console.log(`Array.isArray string: ${Array.isArray("not a list")}`)
console.log(`Array.isArray object: ${Array.isArray({ value: "x" })}`)

console.log(`isSafeInteger(42): ${Number.isSafeInteger(42)}`)
console.log(`isSafeInteger(3.0): ${Number.isSafeInteger(3.0)}`)
console.log(`isSafeInteger(9007199254740991): ${Number.isSafeInteger(9007199254740991)}`)
console.log(`isSafeInteger(9007199254740992): ${Number.isSafeInteger(9007199254740992)}`)
console.log(`isSafeInteger(3.5): ${Number.isSafeInteger(3.5)}`)
console.log(`isSafeInteger("42"): ${Number.isSafeInteger("42")}`)

console.log(`isNaN(123): ${Number.isNaN(123)}`)
console.log(`isNaN("123"): ${Number.isNaN("123")}`)
console.log(`MAX_SAFE_INTEGER: ${Number.MAX_SAFE_INTEGER}`)
console.log(`MIN_SAFE_INTEGER: ${Number.MIN_SAFE_INTEGER}`)
console.log(`EPSILON: ${Number.EPSILON}`)
console.log(`MAX_SAFE_INTEGER safe: ${Number.isSafeInteger(Number.MAX_SAFE_INTEGER)}`)
console.log(`MIN_SAFE_INTEGER safe: ${Number.isSafeInteger(Number.MIN_SAFE_INTEGER)}`)
console.log(`MAX_SAFE_INTEGER plus one safe: ${Number.isSafeInteger(Number.MAX_SAFE_INTEGER + 1)}`)
