console.log(["a", "b", "c"].fill("x").join(","))
console.log(["a", "b", "c", "d"].fill("x", 1, -1).join(","))
console.log(["a", "b", "c", "d"].fill("x", -3, -1).join(","))
console.log(["a", "b"].fill("x", 4).join(","))

let items = ["a", "b", "c"]
items.fill("z", -2)
console.log(items.join(","))

let empty: string[] = []
console.log(empty.fill("x").length)

let oneBlank = [""]
console.log(oneBlank.fill("x").join(","))
