const word = "hello"

console.log(word.substr(1, 3))
console.log(word.substr(-2))
console.log(word.substr(-4, 2))
console.log(word.substr(1, -1))
console.log(word.substr(99))

let dynamic = "bye"
while (true) {
    dynamic = "hello"
    break
}

console.log(dynamic.substr(1, 3))
console.log(dynamic.substr(-2))
