// String stress-test cases for besht compiler

const s01 = "simple double quoted string"
const s02 = 'simple single quoted string'
const s03 = "contains 'single quotes' safely"
const s04 = 'contains "double quotes" safely'
const s05 = "escaped double quote: \"hello\""
const s06 = 'escaped single quote: \'hello\''
const s07 = "backslash path: C:\\Users\\Victor\\Documents\\file.txt"
const s08 = "newline escape: first line\nsecond line"
