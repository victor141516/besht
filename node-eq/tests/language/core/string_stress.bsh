// Simple TypeScript feature/API examples
let nameText = "Victor"
let greeting = "Hello, " + nameText
greeting = greeting + "!"

let count = 3
count = count + 1
count += 2
count--

let price = 12.5
let quantity = 4
let total = price * quantity
let rounded = Math.round(total)
let fixed = total.toFixed(2)

let parsedInt = Number.parseInt("42", 10)
let parsedFloat = Number.parseFloat("3.1415")
let finiteCheck = Number.isFinite(parsedFloat)
let integerCheck = Number.isInteger(parsedInt)

let upper = greeting.toUpperCase()
let lower = greeting.toLowerCase()
let includesVictor = greeting.includes("Victor")
let replaced = greeting.replace("Victor", "Compiler")
let sliced = greeting.slice(0, 5)

let items: string[] = []
items.push("alpha")
items.push("beta")
items.push("gamma")
let firstItem = items[0]
let itemCount = items.length
items[1] = "BETA"

let numbers: number[] = [1, 2, 3]
numbers.push(4)
let sum = numbers[0] + numbers[1] + numbers[2] + numbers[3]

let user = {
  id: 1,
  name: "Victor",
  active: true
}

user.name = "Compiler Tester"
let userLabel = user.name + "#" + String(user.id)

if (user.active) {
  userLabel = userLabel + " active"
} else {
  userLabel = userLabel + " inactive"
}

let score = 87
let grade = ""

if (score >= 90) {
  grade = "A"
} else if (score >= 80) {
  grade = "B"
} else if (score >= 70) {
  grade = "C"
} else {
  grade = "D"
}

let loopText = ""
for (let i = 0; i < 5; i++) {
  loopText = loopText + String(i)
}

let index = 0
while (index < 3) {
  loopText = loopText + "-"
  index++
}

let mode = "dev"
let message = ""

switch (mode) {
  case "dev":
    message = "development"
    break
  case "prod":
    message = "production"
    break
  default:
    message = "unknown"
    break
}

function add(a: number, b: number): number {
  return a + b
}

function makeLabel(prefix: string, value: number): string {
  return prefix + ": " + String(value)
}

let added = add(10, 20)
let label = makeLabel("result", added)

let maybeValue: string | null = "present"
let safeValue = maybeValue === null ? "missing" : maybeValue

let tuple: [string, number] = ["age", 30]
let tupleText = tuple[0] + "=" + String(tuple[1])

let flag = true
let negated = !flag
let combined = flag && finiteCheck
let either = negated || integerCheck

let finalOutput =
  greeting +
  " | " +
  userLabel +
  " | " +
  grade +
  " | " +
  message +
  " | " +
  label

console.log(`greeting: ${greeting}`)
console.log(`count: ${count}`)
console.log(`total: ${total}`)
console.log(`rounded: ${rounded}`)
console.log(`fixed: ${fixed}`)
console.log(`parsedInt: ${parsedInt}`)
console.log(`parsedFloat: ${parsedFloat}`)
console.log(`finiteCheck: ${finiteCheck}`)
console.log(`integerCheck: ${integerCheck}`)
console.log(`upper: ${upper}`)
console.log(`lower: ${lower}`)
console.log(`includesVictor: ${includesVictor}`)
console.log(`replaced: ${replaced}`)
console.log(`sliced: ${sliced}`)
console.log(`firstItem: ${firstItem}`)
console.log(`itemCount: ${itemCount}`)
console.log(`sum: ${sum}`)
console.log(`userLabel: ${userLabel}`)
console.log(`grade: ${grade}`)
console.log(`loopText: ${loopText}`)
console.log(`message: ${message}`)
console.log(`added: ${added}`)
console.log(`label: ${label}`)
console.log(`safeValue: ${safeValue}`)
console.log(`tupleText: ${tupleText}`)
console.log(`negated: ${negated}`)
console.log(`combined: ${combined}`)
console.log(`either: ${either}`)
console.log(`finalOutput: ${finalOutput}`)
