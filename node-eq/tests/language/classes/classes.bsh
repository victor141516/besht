class User {
  name: string
  age: number

  constructor(name: string, age: number) {
    this.name = name
    this.age = age
  }

  greet(): string {
    return "Hello, " + this.name
  }

  isAdult(): boolean {
    return this.age >= 18
  }

  status(): string {
    return this.name + " is ready"
  }

  get label(): string {
    return this.name + " (" + this.age.toString() + ")"
  }

  set label(value: string) {
    this.name = value
  }
}

let u = new User("Alice", 30)
console.log(u.greet())
console.log(u.name)
u.name = "Bob"
console.log(u.name)
console.log(u.label)
u.label = "Carol"
console.log(u.label)
console.log(u.isAdult())
console.log(u.status())

class MathUtils {
  static PI: number = 3.14159

  static get label(): string {
    return "math"
  }

  static round(n: number): number {
    return Math.round(n)
  }
}

console.log(MathUtils.PI)
console.log(MathUtils.label)
console.log(MathUtils.round(2.7))
