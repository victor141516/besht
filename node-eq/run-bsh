#!/usr/bin/env bun
/**
 * run-bsh — execute a .bsh file in the Bun/TypeScript runtime.
 *
 * Usage:  bun run-bsh <file.bsh> [script args...]
 *         ./run-bsh <file.bsh> [script args...]
 *
 * The runtime globals ($, Besht, fetch, …) are injected before the file runs.
 * declare statements in the file are TypeScript no-ops and ignored by Bun.
 */

import { writeFileSync, unlinkSync, readFileSync, existsSync } from "node:fs"
import { join, resolve, dirname, basename, extname, relative } from "node:path"
import { spawnSync } from "node:child_process"

const target = process.argv[2]
if (!target) {
  console.error("Usage: run-bsh <file.bsh> [script args...]")
  process.exit(1)
}
const scriptArgs = process.argv.slice(3)

const absTarget = resolve(target)
const runtimePath = resolve(dirname(import.meta.path), "runtime.ts")
const tempFiles: string[] = []
const materialized = new Map<string, string>()

function collectArgSchema(code: string): { options: string[]; flags: string[] } {
  const options = new Set<string>()
  const flags = new Set<string>()
  const re = /Besht\.args\.(option|flag)\(\s*(["'])([^"']+)\2\s*(?:,\s*(["'])([^"']+)\4\s*)?\)/g
  for (const match of code.matchAll(re)) {
    const target = match[1] === "option" ? options : flags
    target.add(`--${match[3]}`)
    if (match[5]) target.add(`-${match[5]}`)
  }
  return { options: [...options], flags: [...flags] }
}

function stripDeclares(code: string): string {
  return code
    .replace(/^declare\s+class\s+[\s\S]*?\n\}/gm, "")
    .replace(/^declare\s+(?:function|const|type|namespace|var|interface)[^\n]*/gm, "")
    .replace(/^\s*\n/gm, "\n")
    .trimStart()
}

function transformRawStrings(code: string): string {
  let out = ""
  let i = 0
  const ident = /[A-Za-z0-9_$]/

  while (i < code.length) {
    if (code[i] === "r" && code[i + 1] === "\"" && (i === 0 || !ident.test(code[i - 1]))) {
      i += 2
      let value = ""
      while (i < code.length) {
        const ch = code[i]
        if (ch === "\"") {
          i++
          break
        }
        if (ch === "\\") {
          i++
          if (i >= code.length) {
            value += "\\"
            break
          }
          const escaped = code[i]
          if (escaped === "\"" || escaped === "\\") value += escaped
          else value += `\\${escaped}`
          i++
          continue
        }
        value += ch
        i++
      }
      out += JSON.stringify(value)
      continue
    }
    out += code[i]
    i++
  }

  return out
}

function resolveBshImport(source: string, fromFile: string): string | null {
  if (!source.startsWith("./") && !source.startsWith("../")) return null
  const base = resolve(dirname(fromFile), source)
  if (extname(base) === ".bsh" && existsSync(base)) return base
  if (extname(base) === "" && existsSync(`${base}.bsh`)) return `${base}.bsh`
  return null
}

function resolveShellImport(source: string, fromFile: string): string | null {
  if (!source.startsWith("./") && !source.startsWith("../")) return null
  const base = resolve(dirname(fromFile), source)
  if (extname(base) === ".sh" && existsSync(base)) return base
  return null
}

function importSource(fromWrapper: string, toWrapper: string): string {
  let rel = relative(dirname(fromWrapper), toWrapper).replaceAll("\\", "/")
  if (!rel.startsWith("./") && !rel.startsWith("../")) rel = `./${rel}`
  return rel
}

function shellQuote(value: string): string {
  return `'${value.replaceAll("'", `'\"'\"'`)}'`
}

function shellImportBindings(names: string, source: string, fromFile: string): string | null {
  const shellFile = resolveShellImport(source, fromFile)
  if (!shellFile) return null
  return names.split(",").map((part) => {
    const trimmed = part.trim()
    const alias = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)\s+as\s+([A-Za-z_][A-Za-z0-9_]*)$/)
    const direct = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)$/)
    const imported = alias ? alias[1] : direct?.[1]
    const local = alias ? alias[2] : direct?.[1]
    if (!imported || !local) {
      throw new Error(`Unsupported shell import binding: ${trimmed}`)
    }
    const script = `. ${shellQuote(shellFile)}; ${imported} "$@"`
    return `const ${local} = (...args: string[]) => {
  const result = _beshtSpawnSync("sh", ["-c", ${JSON.stringify(script)}, "sh", ...args], { encoding: "utf8" });
  if (result.stderr) process.stderr.write(result.stderr);
  if ((result.status ?? 0) !== 0) process.exitCode = result.status ?? 1;
  return (result.stdout ?? "").replace(/\\n$/, "");
};`
  }).join("\n")
}

function materialize(file: string): string {
  const absFile = resolve(file)
  const existing = materialized.get(absFile)
  if (existing) return existing

  const tmpFile = join(dirname(absFile), `.besht_${basename(absFile, ".bsh")}_${process.pid}_${Date.now()}_${materialized.size}.ts`)
  materialized.set(absFile, tmpFile)
  tempFiles.push(tmpFile)

  let stripped = transformRawStrings(stripDeclares(readFileSync(absFile, "utf8")))
  const schema = collectArgSchema(stripped)
  stripped = stripped.replace(/import\s+\{([^}]+)\}\s+from\s+(['"])(\.{1,2}\/[^'"]+\.sh)\2\s+assert\s*\{\s*type\s*:\s*(['"])shell\4\s*\}\s*;?/g, (match, names, _quote, source) => {
    return shellImportBindings(names, source, absFile) ?? match
  })
  stripped = stripped.replace(/(import\s+(?:[^'";]+?\s+from\s+)?)(['"])(\.{1,2}\/[^'"]+)(\2)/g, (match, prefix, quote, source, suffix) => {
    const dep = resolveBshImport(source, absFile)
    if (!dep) return match
    return `${prefix}${quote}${importSource(tmpFile, materialize(dep))}${suffix}`
  })

  const wrapper = `
import {
  $, Besht, fetch,
  Command,
} from ${JSON.stringify(runtimePath)};
import { spawnSync as _beshtSpawnSync } from "node:child_process";

const _runtime = {
  $, Besht, fetch,
  Command,
};
Object.assign(globalThis, _runtime);
Besht.args.configure(${JSON.stringify(schema.options)}, ${JSON.stringify(schema.flags)});

${stripped}
`.trimStart()

  writeFileSync(tmpFile, wrapper, "utf8")
  return tmpFile
}

let exitCode = 0
try {
  const result = spawnSync("bun", ["run", materialize(absTarget), ...scriptArgs], {
    stdio: "inherit",
    env: { ...process.env },
  })
  exitCode = result.status ?? 0
} finally {
  for (const file of tempFiles.reverse()) {
    try { unlinkSync(file) } catch {}
  }
}
process.exit(exitCode)
